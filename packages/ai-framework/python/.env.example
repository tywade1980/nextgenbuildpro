# AI Framework — Environment Variables

# xAI (primary LLM — Grok)
XAI_API_KEY=your_xai_api_key_here

# OpenRouter (fallback)
OPENROUTER_API_KEY=your_openrouter_key_here

# Anthropic (document analysis)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (GPT-4 workflows)
OPENAI_API_KEY=your_openai_key_here

# Deepgram (STT)
DEEPGRAM_API_KEY=your_deepgram_key_here

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Honcho (persistent memory)
HONCHO_API_KEY=your_honcho_key_here

# RunPod (GPU inference)
RUNPOD_API_KEY=your_runpod_key_here

# Model selection
LLM_MODEL=grok-3-mini

# Deployment
ORCHESTRATOR_PORT=8001
