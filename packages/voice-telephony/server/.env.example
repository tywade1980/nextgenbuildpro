# Voice & Telephony Gateway — Environment Variables

# xAI Realtime (Caroline voice)
XAI_API_KEY=your_xai_api_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_key_here

# Twilio (SIP/PSTN)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here

# SIP configuration
SIP_DOMAIN=your_sip_domain_here
SIP_USERNAME=your_sip_username_here
SIP_PASSWORD=your_sip_password_here

# Aria-voice Python sidecar
ARIA_BACKEND_URL=http://localhost:8002

# Feature flags
SIP_ENABLED=false
WEBRTC_ENABLED=true

# Security
JWT_SECRET=change_this_secret_in_production

# Deployment
PORT=3001
