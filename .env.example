# Firebase Configuration
# Get these values from your Firebase project console: https://console.firebase.google.com/
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key-here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# OpenRouter API (for AI features)
OPENROUTER_API_KEY=your-openrouter-api-key

# Construction Cost APIs (optional)
RSMEANS_API_KEY=your-rsmeans-api-key
BLS_API_KEY=your-bls-api-key

# Development Settings
NODE_ENV=development
REACT_APP_DEBUG=true

